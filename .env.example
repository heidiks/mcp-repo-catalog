# =============================================================================
# mcp-repo-catalog configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Azure DevOps ---
# Organization name (e.g. "my-org")
AZURE_DEVOPS_ORG=
# Personal Access Token (scopes: Code Read, Project and Team Read)
AZURE_DEVOPS_TOKEN=
# Local path where ADO repos are cloned (optional)
# The tool will look for repos as: $AZURE_DEVOPS_REPOS_PATH/<repo-name>/
AZURE_DEVOPS_REPOS_PATH=

# --- GitHub ---
# Personal Access Token (scope: repo or public_repo)
GITHUB_TOKEN=
# Comma-separated list of GitHub organizations to list (optional)
GITHUB_ORGS=
# GitHub username for personal repos (optional)
GITHUB_USER=
# Local path where GitHub repos are cloned (optional)
# The tool will look for repos as: $GITHUB_REPOS_PATH/<repo-name>/
# or: $GITHUB_REPOS_PATH/<owner>/<repo-name>/
GITHUB_REPOS_PATH=

# --- Remote catalog (optional, for org-wide shared catalog) ---
# Git repo URL containing .md catalog files
CATALOG_REMOTE_REPO=
# Path within the repo where .md files are (default: catalog/, then root)
CATALOG_REMOTE_PATH=

# --- Provider control ---
# Comma-separated list of providers to disable (e.g. "github" or "azuredevops")
DISABLED_PROVIDERS=
